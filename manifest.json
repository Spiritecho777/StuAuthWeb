{
  "description": "Authenticator generates 2-Step Verification codes in your browser (StuAuthDesktop or StuAuthMobile required)",
  "manifest_version": 2,
  "name": "StuAuthWeb",
  "version": "3.21",
  "icons": {
    "48": "icons/icon48.png"
  },
  "permissions": [
    "storage",
    "clipboardWrite",
    "http://*/*"
  ],
  "browser_action": {
    "default_icon": "icons/icon48.png",
    "default_title": "StuAuthWeb",
    "default_popup": "app.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "StuAuthWeb@example.com",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}